<!--
  Combined YAM arm (6-DOF) + Aero Hand Right (16-DOF) MuJoCo scene.

  The hand's `tetheria_mount` body is attached to the YAM arm's `link_6` so
  that the Aero Hand follows the wrist.  No physics step is needed — the
  viewer applies FK-only by writing qpos directly.

  External model paths (absolute):
    YAM meshes  : /home/dragonx/tetheria/i2rt/i2rt/robot_models/yam/assets/
    Aero Hand   : /home/dragonx/tetheria/mujoco_menagerie/tetheria_aero_hand_open/right_hand.xml
-->
<mujoco model="yam_with_hand">
  <compiler angle="radian"
            meshdir="/home/dragonx/tetheria/i2rt/i2rt/robot_models/yam/assets/"/>

  <statistic center="0.2 0 0.4" extent="1.2"/>

  <visual>
    <headlight diffuse="0.7 0.7 0.7" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-20"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.55 0.75 0.95" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.5 0.5 0.5" rgb2="0.3 0.3 0.3" markrgb="0.4 0.4 0.4"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>

    <!-- YAM arm meshes (resolved via meshdir above) -->
    <mesh name="base_link_collision" file="base_link_collision.stl"/>
    <mesh name="link_1_collision"    file="link_1_collision.stl"/>
    <mesh name="link_2_collision"    file="link_2_collision.stl"/>
    <mesh name="link_3_collision"    file="link_3_collision.stl"/>
    <mesh name="link_4_collision"    file="link_4_collision.stl"/>
    <mesh name="link_5_collision"    file="link_5_collision.stl"/>
    <mesh name="link_6_collision"    file="link_6_collision.stl"/>

    <!-- Aero Hand model — loaded as an asset, attached inside link_6 below -->
    <model name="aero_hand"
           file="/home/dragonx/tetheria/mujoco_menagerie/tetheria_aero_hand_open/right_hand.xml"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1" directional="true"/>
    <light pos="1 1 2" dir="-0.5 -0.5 -1" directional="true" diffuse="0.3 0.3 0.3"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- YAM arm static base plate (cosmetic cylinder approximation) -->
    <geom name="yam_base_plate" type="cylinder" size="0.085 0.016"
          pos="0 0 0.016" rgba="0.65 0.65 0.65 1" contype="0" conaffinity="0"/>

    <!-- ── YAM arm kinematic chain ──────────────────────────────────── -->
    <body name="link_1" pos="0 0 0.0631" quat="1 0 0 1">
      <inertial pos="-0.00192861 -0.00795735 0.0208176"
                quat="0.297851 0.642634 0.360045 0.607185"
                mass="0.12415" diaginertia="0.000180751 0.000145532 5.89179e-05"/>
      <joint name="joint1" pos="0 0 0" axis="0 0 1" range="-2.61799 3.13"/>
      <geom pos="-0.00192861 -0.00795735 0.0208176"
            quat="0.707105 0 0 -0.707108" type="mesh" rgba="1 0.6 0 1"
            mesh="link_1_collision"/>

      <body name="link_2" pos="2.5e-05 -0.02 0.0409" quat="1 1 1 1">
        <inertial pos="0.132008 2.10599e-06 0.000293073"
                  quat="1 1 1 1" mass="1.24434"
                  diaginertia="0.0121902 0.0121318 0.000683304"/>
        <joint name="joint2" pos="0 0 0" axis="0 0 1" range="0 3.65"/>
        <geom pos="0.132008 2.10599e-06 0.000293073"
              quat="9.38184e-07 9.38187e-07 0.707108 0.707105" type="mesh"
              rgba="1 0.6 0 1" mesh="link_2_collision"/>

        <body name="link_3" pos="0.264 0 0" quat="0 1 0 0">
          <inertial pos="-0.121816 -0.054846 -0.000111108"
                    quat="1 1 1 1" mass="0.853698"
                    diaginertia="0.00699732 0.00696112 0.000788244"/>
          <joint name="joint3" pos="0 0 0" axis="0 0 1" range="0 3.13"/>
          <geom pos="-0.121816 -0.054846 -0.000111108"
                quat="9.38184e-07 -9.38187e-07 0.707108 -0.707105" type="mesh"
                rgba="1 0.6 0 1" mesh="link_3_collision"/>

          <body name="link_4" pos="-0.245 -0.06 0" quat="1 0 0 0">
            <inertial pos="-0.0769778 -0.0527104 0.000154878"
                      quat="0.667 0.667 -0.236 -0.236" mass="0.463511"
                      diaginertia="0.000791532 0.000744733 0.000282116"/>
            <joint name="joint4" pos="0 0 0" axis="0 0 1" range="-1.65 1.65"/>
            <geom pos="-0.0569778 -0.0527104 0.000154878"
                  quat="9.38184e-07 -9.38187e-07 0.707108 -0.707105" type="mesh"
                  rgba="1 0.6 0 1" mesh="link_4_collision"/>

            <body name="link_5" pos="-0.074 -0.0395 2.5e-05" quat="1 -1 1 1">
              <inertial pos="3.64861e-05 0.00025665 0.0353526"
                        quat="1 0 0 0" mass="0.350962"
                        diaginertia="0.000197802 0.0001775 0.000147402"/>
              <joint name="joint5" pos="0 0 0" axis="0 0 1"
                     range="-1.5708 1.5708"/>
              <geom pos="3.64861e-05 0.00025665 0.0353526"
                    quat="9.38184e-07 -0.707105 -0.707108 9.38187e-07"
                    type="mesh" rgba="1 0.6 0 1" mesh="link_5_collision"/>

              <body name="link_6" pos="0 0.0353 0.0395" quat="1 -1 0 0">
                <inertial pos="-5.10177e-05 -0.00269952 0.0581778"
                          quat="0.98383 0.174699 0.0 0.0" mass="0.55366"
                          diaginertia="0.000956992 0.000799286 0.000469547"/>
                <joint name="joint6" pos="0 0 0" axis="0 0 1"
                       range="-2.0944 2.0944"/>
                <geom pos="-5.10177e-05 -0.00269952 0.0481778"
                      quat="1 -1 -1 -1" type="mesh" rgba="1 0.6 0 1"
                      mesh="link_6_collision"/>
                <site name="tcp_site"   pos="0 0 0"      quat="1 0 0 -1"
                      size="0.006" rgba="1 0 0 1"/>
                <site name="grasp_site" pos="0 0 0.1347" quat="1 0 0 -1"
                      size="0.006" rgba="0 1 0 1"/>

                <!-- ── Aero Hand attached at wrist ────────────────────── -->
                <!-- The hand's tetheria_mount body sits at the TCP.
                     All hand joints and bodies get the prefix "hand_".     -->
                <attach model="aero_hand" body="tetheria_mount" prefix="hand_"/>

              </body>  <!-- link_6 -->
            </body>  <!-- link_5 -->
          </body>  <!-- link_4 -->
        </body>  <!-- link_3 -->
      </body>  <!-- link_2 -->
    </body>  <!-- link_1 -->

  </worldbody>

</mujoco>
